{
  "name": "@dc/desktop",
  "version": "0.7.1",
  "private": true,
  "description": "Dota 2 Companion desktop app (Electron)",
  "author": "NeuroFocus <hello@neurofocus.dev> (https://neurofocus.dev)",
  "homepage": "https://neurofocus.dev",
  "main": "dist/main.cjs",
  "scripts": {
    "build:main": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist/main.cjs",
    "dist": "npm run build:main && electron-builder --config electron-builder.yml --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.1"
  }
}
