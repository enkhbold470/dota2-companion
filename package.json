{
  "name": "dota2-companion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "start": "pnpm --filter @dc/overlay build && node --import tsx apps/listener/src/main.ts",
    "listener": "pnpm --filter @dc/listener dev",
    "overlay": "pnpm --filter @dc/overlay dev",
    "replay": "pnpm --filter @dc/listener replay",
    "gen-cfg": "node scripts/gen-gsi-cfg.mjs",
    "gen-data": "node scripts/gen-coach-data.mjs",
    "gen-hero-builds": "node scripts/gen-hero-builds.mjs"
  },
  "devDependencies": {
    "dotaconstants": "^10.8.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "!apps/desktop"
  ]
}
