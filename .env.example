# Copy to .env and fill in. .env is gitignored; this template is committed.
# The listener auto-loads .env via `--env-file-if-exists` (see package.json).

# Enables Ask Coach (POST /coach → OpenAI gpt-4o). Without it, /coach returns
# 501 and the overlay's Ask panel shows a setup hint; everything else works.
OPENAI_API_KEY=

# Must match the auth token in the GSI .cfg you copy into Dota 2.
# Run `pnpm gen-cfg` to generate both the .cfg and .gsi-token, then paste here.
GSI_TOKEN=
